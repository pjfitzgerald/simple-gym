#!/usr/bin/env bash
#
# Auto-deploy to local prod after a pull/merge into main only. Mirror of
# post-commit -- covers the case where main is updated via `git pull`
# (e.g. commits pushed from another machine) rather than a local commit.
#
branch="$(git symbolic-ref --short HEAD 2>/dev/null || true)"
[ "$branch" = "main" ] || exit 0

repo="$(git rev-parse --show-toplevel)"
mkdir -p "$repo/data"
echo "post-merge -> deploying main to simple-gym prod (log: data/deploy.log)"
nohup "$repo/scripts/deploy.sh" >> "$repo/data/deploy.log" 2>&1 &
